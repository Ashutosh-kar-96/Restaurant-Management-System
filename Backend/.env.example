# ── Server
NODE_ENV=production
PORT=9001

# ── Database (MySQL)
DATABASE_URL="mysql://root:root@localhost:3306/rms_db"

# ── JWT Secrets (use long random strings in production)
JWT_SECRET=your_very_long_random_jwt_secret_here_change_this
JWT_REFRESH_SECRET=your_very_long_random_refresh_secret_here_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES=7d

# ── Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173

# ── File Uploads
MAX_FILE_SIZE=5242880
