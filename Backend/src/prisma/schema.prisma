// src/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  MANAGER
  WAITER
  CHEF
  CASHIER
  CUSTOMER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  ONLINE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  CANCELLED
  REFUNDED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum PaymentMode {
  CASH
  CARD
  UPI
  ONLINE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_PAID
}

enum ItemVariant {
  HALF
  FULL
  REGULAR
  LARGE
  EXTRA_LARGE
}

enum StockAlertLevel {
  NORMAL
  LOW
  CRITICAL
  OUT_OF_STOCK
}

enum BookingStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  ORDER_PLACED
  ORDER_READY
  ORDER_SERVED
  PAYMENT_SUCCESS
  LOW_STOCK
  TABLE_BOOKED
  FEEDBACK_RECEIVED
  SYSTEM_ALERT
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?   @unique
  password     String
  firstName    String
  lastName     String
  role         Role      @default(CUSTOMER)
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  avatar       String?
  refreshToken String?   @db.Text
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurantStaff RestaurantStaff[]
  orders          Order[]           @relation("CustomerOrders")
  assignedOrders  Order[]           @relation("WaiterOrders")
  payments        Payment[]
  bookings        TableBooking[]
  feedbacks       Feedback[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  sentMessages    ChatMessage[]     @relation("SentMessages")

  @@map("users")
}

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?  @db.Text
  email       String
  phone       String
  website     String?
  gstin       String?
  address     String?  @db.Text
  city        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branches       Branch[]
  staff          RestaurantStaff[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]

  @@map("restaurants")
}

